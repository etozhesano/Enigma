    <style name="CalendarDayOfTheWeekText">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#4F4F4F</item>
        <item name="fontPath">font/Cabin-Regular.ttf</item>
    </style>

    <style name="CalendarDayOfTheMonthText">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#4F4F4F</item>
        <item name="fontPath">font/cabinbold.ttf</item>
    </style>

</resources>