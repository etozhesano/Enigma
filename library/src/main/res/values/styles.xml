<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="AppBaseTheme" parent="android:Theme.Light" />

    <!-- Application theme. -->
    <style name="AppTheme" parent="AppBaseTheme">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>

    <style name="CalendarMonthText">
        <item name="fontPath">fonts/OverrideThisWithYourFontPath</item>
        <item name="android:textSize">@dimen/calendar_month_font</item>
        <item name="android:textColor">@color/calendar_month_font</item>
    </style>

    <style name="CalendarMonthArrow">
        <item name="android:tint">@color/calendar_month_arrow</item>
    </style>

    <style name="CalendarDayOfTheWeekText">
        <item name="fontPath">fonts/OverrideThisWithYourFontPath</item>
        <item name="android:textSize">@dimen/calendar_day_of_week_font</item>
        <item name="android:textColor">@color/calendar_day_of_the_month_font</item>
    </style>

    <style name="CalendarDayOfTheMonthText">
        <item name="fontPath">fonts/OverrideThisWithYourFontPath</item>
        <item name="android:textSize">@dimen/calendar_day_of_the_month_font</item>
        <item name="android:textColor">@color/calendar_day_of_the_month_font</item>
    </style>

</resources>